{
  "name": "react-remote-combo",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "keywords": [
  "react",
  "autocomplete",
  "search",
  "pagination",
  "infinite-scroll",
  "combobox"
],
"repository": {
  "type": "git",
  "url": "https://github.com/elgedawy31/react-remote-compo"
},
"description": "Reusable remote autocomplete with pagination for React",
"scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run build:lib",
    "build:lib": "vite build --config vite.lib.config.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "@tanstack/react-query": "^5",
    "@radix-ui/react-popover": "^1",
    "cmdk": "^1",
    "lucide-react": ">=0.400.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.90.16",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cmdk": "^1.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
